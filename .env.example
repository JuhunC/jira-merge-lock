# jira-merge-lock configuration — copy to .env and fill in.
# Empty values are treated as unset; startup fails listing ALL problems at once.

# ── GitHub App ───────────────────────────────────────────────────────────────

# Numeric GitHub App id (shown on the app's settings page). Required.
APP_ID=

# App private key: set EXACTLY ONE of PRIVATE_KEY / PRIVATE_KEY_PATH.
# PRIVATE_KEY: the PEM contents (base64-encoded PEM also accepted).
PRIVATE_KEY=
# PRIVATE_KEY_PATH: path to a mounted PEM file (see docker-compose.yml volumes).
#PRIVATE_KEY_PATH=/keys/app.pem

# Webhook secret configured on the GitHub App. Required.
WEBHOOK_SECRET=

# ── Server ───────────────────────────────────────────────────────────────────

# HTTP port for webhooks + /healthz + /readyz + the guidelines homepage.
#PORT=3000

# Listen address. Keep 0.0.0.0 in containers (loopback-only binds make the
# published port unreachable); restrict exposure via the compose port mapping.
#HOST=0.0.0.0

# Public base URL of this deployment (the reverse-proxied HTTPS host). Optional;
# when set, every check run links to the guidelines homepage served at /.
#PUBLIC_URL=https://jira-merge-lock.example.com

# GitHub Enterprise Server? Set your instance hostname (the app then talks to
# https://<GHE_HOST>/api/v3 instead of github.com). Leave unset for github.com.
#GHE_HOST=github.yourco.com
#GHE_PROTOCOL=https

# Log verbosity: trace|debug|info|warn|error|fatal|silent.
#LOG_LEVEL=info

# Log output: json (production) or pretty (local development).
#LOG_FORMAT=json

# ── Jira connection ──────────────────────────────────────────────────────────

# Jira base URL, no trailing slash (also used to build /browse/ links). Required.
JIRA_BASE_URL=

# Auth mode: cloud | pat | basic. Required — then fill EXACTLY ONE block below.
JIRA_AUTH_METHOD=

# (1) cloud — Jira Cloud: Atlassian account email + API token.
#JIRA_EMAIL=
#JIRA_API_TOKEN=

# (2) pat — Jira Server/Data Center 8.14+: personal access token (Bearer).
#JIRA_PAT=

# (3) basic — legacy Jira Server: username + password.
#    Note: repeated auth failures can trip Jira's CAPTCHA lockout.
#JIRA_USERNAME=
#JIRA_PASSWORD=

# Per-request Jira timeout in milliseconds.
#JIRA_TIMEOUT_MS=10000

# Per-request timeout for GitHub API calls (ms).
#GITHUB_TIMEOUT_MS=30000

# ── Lock policy ──────────────────────────────────────────────────────────────

# Comma-separated status names that count as done (trimmed, case-insensitive).
#JIRA_DONE_STATUSES=Closed,Resolved

# true: an issue whose statusCategory is "done" also counts (rename/locale-proof).
#JIRA_DONE_USE_CATEGORY=false

# Regex (word-boundary wrapped automatically) for Jira keys in commit messages.
#JIRA_KEY_REGEX=[A-Z][A-Z0-9]+-\d+

# Comma-separated project-key allowlist, e.g. PRJ,OPS. Empty = all projects.
# Recommended: kills false positives like UTF-8 / SHA-256.
#JIRA_PROJECT_KEYS=

# true: PRs referencing zero Jira issues FAIL instead of passing.
#REQUIRE_ISSUE_KEY=false

# ── Ruleset integration ──────────────────────────────────────────────────────

# Org rulesets whose name starts with this prefix define which repos/branches
# are locked; the app auto-injects its required check into them.
#RULESET_NAME_PREFIX=jira-merge-lock

# false = hardened mode: the app never writes rulesets; an admin maintains the
# required-check entry by hand (see README).
#RULESET_AUTOCONFIGURE=true

# Name of the check run / required status context posted by the app.
#CHECK_NAME=jira-merge-lock

# ── Poller ───────────────────────────────────────────────────────────────────

# Seconds between re-scans of open PRs (picks up Jira-side changes). 0 disables.
#POLL_INTERVAL_SECONDS=300

# Repos evaluated concurrently per installation during a poll cycle.
#POLL_CONCURRENCY=5
